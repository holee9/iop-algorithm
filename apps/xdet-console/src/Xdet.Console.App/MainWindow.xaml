<Window x:Class="Xdet.Console.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="XDET Engine Seam - SPEC-XSEAM-001 P1.5"
        Height="760" Width="1240"
        Loaded="Window_Loaded">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" AutomationProperties.AutomationId="StatusText"
                           Text="engine: not initialized" />
            </StatusBarItem>
        </StatusBar>

        <TabControl>
            <!-- Viewer (feat/xseam-ui-expand): the PRIMARY flow is the REGISTERED edrogi
                 test set. Pick an arm (Offset/MasterDark, Gain/CalSet_19008, Defect/BPM)
                 and run it: the seam runs the golden stage on the REAL 아크릴 3072x3072
                 acquisition with the REAL CalibSet (mirroring the frozen Python realdata
                 arms) -> engine-computed sanity + stats (incl. max|delta|, proving the REAL
                 correction) + engine-downsampled before/after previews. QUARANTINE sanity
                 (labeled, never a numeric golden). Save applies the C-20 write guard
                 engine-side. The arbitrary "Open image..." path is retained as SECONDARY.
                 The UI does no DSP and no downsampling (SPEC-VIEWER-001). -->
            <TabItem Header="Viewer (registered test set)" AutomationProperties.AutomationId="ViewerTab"
                     IsSelected="True">
                <DockPanel>
                    <!-- PRIMARY: registered edrogi test set (real signal + real calib). -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,8,8,2">
                        <TextBlock Text="Registered test set:" VerticalAlignment="Center"
                                   FontWeight="Bold" Margin="0,0,8,0" />
                        <ComboBox x:Name="ArmSelector" AutomationProperties.AutomationId="ArmSelector"
                                  Width="200" SelectedIndex="0" VerticalContentAlignment="Center">
                            <ComboBoxItem Tag="offset" Content="Offset (MasterDark)" />
                            <ComboBoxItem Tag="gain" Content="Gain (CalSet_19008)" />
                            <ComboBoxItem Tag="defect" Content="Defect (BPM)" />
                        </ComboBox>
                        <Button x:Name="RunRegisteredArmButton" AutomationProperties.AutomationId="RunRegisteredArmButton"
                                Content="Run registered arm"
                                Click="RunRegisteredArmButton_Click" Padding="10,4" Margin="8,0,0,0" />
                        <Button x:Name="ViewerSaveButton" AutomationProperties.AutomationId="ViewerSaveButton"
                                Content="Save output..." IsEnabled="False"
                                Click="ViewerSaveButton_Click" Padding="10,4" Margin="8,0,0,0" />
                    </StackPanel>
                    <!-- SECONDARY: arbitrary browse -> golden offset (synthetic zero dark). -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,6">
                        <TextBlock Text="Arbitrary image:" VerticalAlignment="Center"
                                   Foreground="Gray" Margin="0,0,8,0" />
                        <Button x:Name="OpenImageButton" AutomationProperties.AutomationId="OpenImageButton"
                                Content="Open image..."
                                Click="OpenImageButton_Click" Padding="10,4" />
                        <Button x:Name="ViewerProcessButton" AutomationProperties.AutomationId="ViewerProcessButton"
                                Content="Run offset" IsEnabled="False"
                                Click="ViewerProcessButton_Click" Padding="10,4" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="8,0,8,4">
                        <TextBlock x:Name="ViewerInfo" AutomationProperties.AutomationId="ViewerInfo"
                                   Text="Pick a registered arm and click 'Run registered arm' (or open an arbitrary image)."
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="ViewerStatus" AutomationProperties.AutomationId="ViewerStatus"
                                   Text="viewer: idle" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <!-- Shared Window/Level (C-01): min/max exact entry sets the SAME color
                         range on the before AND after heatmaps; 'Auto' resets to the
                         before-preview min/max. Pure render (no array copy/DSP). -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,4">
                        <TextBlock Text="Shared W/L:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0" />
                        <TextBlock Text="min" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox x:Name="ViewerWlMin" AutomationProperties.AutomationId="ViewerWlMin"
                                 Width="100" VerticalContentAlignment="Center" />
                        <TextBlock Text="max" VerticalAlignment="Center" Margin="10,0,4,0" />
                        <TextBox x:Name="ViewerWlMax" AutomationProperties.AutomationId="ViewerWlMax"
                                 Width="100" VerticalContentAlignment="Center" />
                        <Button x:Name="ViewerWlAuto" AutomationProperties.AutomationId="ViewerWlAuto"
                                Content="Auto" Padding="10,2" Margin="10,0,0,0" />
                    </StackPanel>
                    <!-- Hover pixel probe (C-03): reads STORED float32 before/after/diff. -->
                    <TextBlock x:Name="ViewerProbeLabel" AutomationProperties.AutomationId="ViewerProbeLabel"
                               DockPanel.Dock="Bottom" Margin="8,2,8,6" TextWrapping="Wrap"
                               Text="probe (row,col): move mouse over a heatmap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot x:Name="ViewerBeforePlot" Grid.Column="0" />
                        <sp:WpfPlot x:Name="ViewerAfterPlot" Grid.Column="1" />
                        <sp:WpfPlot x:Name="ViewerDiffPlot" AutomationProperties.AutomationId="ViewerDiffPlot"
                                    Grid.Column="2" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Pipeline seam (feat/xseam-ui-expand): the golden orchestrator runs the
                 REAL offset -> gain subsequence of CANONICAL_ORDER on the REGISTERED edrogi
                 아크릴 3072x3072 frame with a calib_map of the REAL CalibSets (offset from
                 MasterDark, gain from CalSet_19008 — both panel_id SAMPLE-EDROGI-16BIT so the
                 orchestrator entry gate passes), mirroring tests/pipeline (CANONICAL_ORDER
                 subsequence + validation_mode intermediates). The UI renders the engine-
                 downsampled before/after/diff heatmaps with the shared W/L + probe and shows
                 engine-computed stage/stat info (incl. max|delta|). QUARANTINE sanity (labeled,
                 never a numeric golden). The UI does no DSP and no downsampling (SPEC-VIEWER-001). -->
            <TabItem Header="Pipeline (registered offset→gain)" AutomationProperties.AutomationId="PipelineTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="PipelineButton" AutomationProperties.AutomationId="PipelineButton"
                                Content="Run registered pipeline (offset→gain, real)"
                                Click="PipelineButton_Click" Padding="10,4" />
                        <TextBlock x:Name="PipelineInfo" AutomationProperties.AutomationId="PipelineInfo"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Shared Window/Level (C-01): same color range on input + output. -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,4">
                        <TextBlock Text="Shared W/L:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0" />
                        <TextBlock Text="min" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox x:Name="PipelineWlMin" AutomationProperties.AutomationId="PipelineWlMin"
                                 Width="100" VerticalContentAlignment="Center" />
                        <TextBlock Text="max" VerticalAlignment="Center" Margin="10,0,4,0" />
                        <TextBox x:Name="PipelineWlMax" AutomationProperties.AutomationId="PipelineWlMax"
                                 Width="100" VerticalContentAlignment="Center" />
                        <Button x:Name="PipelineWlAuto" AutomationProperties.AutomationId="PipelineWlAuto"
                                Content="Auto" Padding="10,2" Margin="10,0,0,0" />
                    </StackPanel>
                    <TextBlock x:Name="PipelineProbeLabel" AutomationProperties.AutomationId="PipelineProbeLabel"
                               DockPanel.Dock="Bottom" Margin="8,2,8,6" TextWrapping="Wrap"
                               Text="probe (row,col): move mouse over a heatmap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot x:Name="PipelineInputPlot" Grid.Column="0" />
                        <sp:WpfPlot x:Name="PipelineOutputPlot" Grid.Column="1" />
                        <sp:WpfPlot x:Name="PipelineDiffPlot" AutomationProperties.AutomationId="PipelineDiffPlot"
                                    Grid.Column="2" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Real Image (SPEC-REALDATA-001): [HARD] QUARANTINE 배관/sanity ONLY.
                 The seam runs the golden OFFSET stage on a REAL edrogi 3072x3072
                 acquisition frame (via the frozen realdata sample arm) purely to prove
                 it EXECUTES and yields finite, non-degenerate output — NOT a numeric
                 golden. The engine returns engine-computed sanity stats + ~512x512
                 block-mean before/after previews; the UI renders them with zero DSP
                 and labels them QUARANTINE (수치 golden 아님). -->
            <TabItem Header="Real Image" AutomationProperties.AutomationId="RealImageTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="RealImageButton" AutomationProperties.AutomationId="RealImageButton"
                                Content="Load real edrogi frame → offset (sanity)"
                                Click="RealImageButton_Click" Padding="10,4" />
                        <TextBlock x:Name="RealImageInfo" AutomationProperties.AutomationId="RealImageInfo"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot x:Name="RealImageInputPlot" Grid.Column="0" />
                        <sp:WpfPlot x:Name="RealImageOutputPlot" Grid.Column="1" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- MTF metric (measurement protocol 1.2): [HARD] SYNTHETIC ONLY. The registered
                 edrogi set has NO slanted-edge phantom, so a REAL MTF is not possible here —
                 it is blocked on the guiding acquisition set (issue #33). This tab keeps the
                 synthetic path: the adapter renders the golden analytic slanted-edge phantom,
                 the seam computes its presampled MTF, and the UI plots the returned frequency
                 vs MTF curve verbatim. Clearly labeled synthetic — it does NOT use registered
                 data. This is the only user-facing synthetic tab that remains. -->
            <TabItem Header="MTF (synthetic edge phantom)" AutomationProperties.AutomationId="MtfTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="MtfButton" AutomationProperties.AutomationId="MtfButton"
                                Content="Compute MTF (synthetic phantom)"
                                Click="MtfButton_Click" Padding="10,4" />
                        <TextBlock x:Name="MtfInfo" AutomationProperties.AutomationId="MtfInfo"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="8,0,8,6" TextWrapping="Wrap"
                               Foreground="#B03030"
                               Text="합성 엣지 팬텀 — 등록 세트에 슬랜티드 엣지 없음, 실측 MTF는 지침 취득세트(#33) 대기. (SYNTHETIC phantom; NOT registered data.)" />
                    <sp:WpfPlot x:Name="MtfPlot" />
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
