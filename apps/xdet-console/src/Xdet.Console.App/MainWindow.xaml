<Window x:Class="Xdet.Console.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="XDET Engine Seam - SPEC-XSEAM-001 P1.5"
        Height="640" Width="920"
        Loaded="Window_Loaded">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" AutomationProperties.AutomationId="StatusText"
                           Text="engine: not initialized" />
            </StatusBarItem>
        </StatusBar>

        <TabControl>
            <!-- Viewer (P0 usable loop, feat/xseam-ui-expand): open an ARBITRARY
                 16-bit test image -> run the golden offset -> view before/after ->
                 save the result. The seam loads/downsamples/processes/exports; the UI
                 only drives the 3 buttons and renders engine-returned previews (no DSP,
                 no downsampling — SPEC-VIEWER-001). Loaded real images are QUARANTINE
                 sanity (labeled, never a numeric golden). Save applies the C-20 write
                 guard (refuse under <repo>/data) engine-side and never crashes. -->
            <TabItem Header="Viewer" AutomationProperties.AutomationId="ViewerTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="OpenImageButton" AutomationProperties.AutomationId="OpenImageButton"
                                Content="Open image..."
                                Click="OpenImageButton_Click" Padding="10,4" />
                        <Button x:Name="ViewerProcessButton" AutomationProperties.AutomationId="ViewerProcessButton"
                                Content="Run offset" IsEnabled="False"
                                Click="ViewerProcessButton_Click" Padding="10,4" Margin="8,0,0,0" />
                        <Button x:Name="ViewerSaveButton" AutomationProperties.AutomationId="ViewerSaveButton"
                                Content="Save output..." IsEnabled="False"
                                Click="ViewerSaveButton_Click" Padding="10,4" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="8,0,8,4">
                        <TextBlock x:Name="ViewerInfo" AutomationProperties.AutomationId="ViewerInfo"
                                   Text="Open a 16-bit .raw test image to begin." TextWrapping="Wrap" />
                        <TextBlock x:Name="ViewerStatus" AutomationProperties.AutomationId="ViewerStatus"
                                   Text="viewer: idle" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot x:Name="ViewerBeforePlot" Grid.Column="0" />
                        <sp:WpfPlot x:Name="ViewerAfterPlot" Grid.Column="1" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Offset stage (SWR-101~104): the seam runs the golden offset on a
                 small deterministic synthetic frame; the UI renders the full 2-D
                 input vs corrected frames as ScottPlot heatmaps. No pixel math is
                 done here — only array selection and rendering. -->
            <TabItem Header="Offset" AutomationProperties.AutomationId="OffsetTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="OffsetButton" AutomationProperties.AutomationId="OffsetButton"
                                Content="Run offset (synthetic)"
                                Click="OffsetButton_Click" Padding="10,4" />
                        <TextBlock x:Name="OffsetInfo" AutomationProperties.AutomationId="OffsetInfo"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot x:Name="OffsetInputPlot" Grid.Column="0" />
                        <sp:WpfPlot x:Name="OffsetOutputPlot" Grid.Column="1" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Pipeline seam: the golden orchestrator runs the minimal valid
                 offset -> gain slice of CANONICAL_ORDER on a synthetic frame with
                 synthetic CalibSet(s). The UI renders input vs output frames as
                 heatmaps and shows engine-computed stage/stat info. No DSP here. -->
            <TabItem Header="Pipeline" AutomationProperties.AutomationId="PipelineTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="PipelineButton" AutomationProperties.AutomationId="PipelineButton"
                                Content="Run pipeline (synthetic)"
                                Click="PipelineButton_Click" Padding="10,4" />
                        <TextBlock x:Name="PipelineInfo" AutomationProperties.AutomationId="PipelineInfo"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot x:Name="PipelineInputPlot" Grid.Column="0" />
                        <sp:WpfPlot x:Name="PipelineOutputPlot" Grid.Column="1" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- MTF metric (measurement protocol 1.2): the adapter renders the golden
                 slanted-edge phantom, the seam computes the presampled MTF, and the UI
                 plots the returned frequency vs MTF curve verbatim. -->
            <TabItem Header="MTF" AutomationProperties.AutomationId="MtfTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="MtfButton" AutomationProperties.AutomationId="MtfButton"
                                Content="Compute MTF"
                                Click="MtfButton_Click" Padding="10,4" />
                        <TextBlock x:Name="MtfInfo" AutomationProperties.AutomationId="MtfInfo"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <sp:WpfPlot x:Name="MtfPlot" />
                </DockPanel>
            </TabItem>

            <!-- Real Image (SPEC-REALDATA-001): [HARD] QUARANTINE 배관/sanity ONLY.
                 The seam runs the golden OFFSET stage on a REAL edrogi 3072x3072
                 acquisition frame (via the frozen realdata sample arm) purely to prove
                 it EXECUTES and yields finite, non-degenerate output — NOT a numeric
                 golden. The engine returns engine-computed sanity stats + ~512x512
                 block-mean before/after previews; the UI renders them with zero DSP
                 and labels them QUARANTINE (수치 golden 아님). -->
            <TabItem Header="Real Image" AutomationProperties.AutomationId="RealImageTab">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <Button x:Name="RealImageButton" AutomationProperties.AutomationId="RealImageButton"
                                Content="Load real edrogi frame → offset (sanity)"
                                Click="RealImageButton_Click" Padding="10,4" />
                        <TextBlock x:Name="RealImageInfo" AutomationProperties.AutomationId="RealImageInfo"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot x:Name="RealImageInputPlot" Grid.Column="0" />
                        <sp:WpfPlot x:Name="RealImageOutputPlot" Grid.Column="1" />
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
